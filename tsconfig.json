    "**/*.mts"
, "app/select-role/page.jsx", "app/staff/staff-crisis-map/page.jsx", "app/staff/staff-home/page.jsx", "app/staff/staff-inventory/page.jsx", "app/staff/staff-login/page.jsx", "app/staff/staff-register/page.jsx", "app/staff/staff-sos/page.jsx", "app/staff/staff-verify/page.jsx", "app/staff/staff-verify-data/page.jsx", "app/staff/staff-verify-success/page.jsx", "app/user/donor-confirm/page.jsx", "app/user/donor-form/page.jsx", "app/user/donor-history/page.jsx", "app/user/donor-home/page.jsx", "app/user/donor-low-products/page.jsx", "app/user/donor-tracking/page.jsx", "app/user/sos-form/page.jsx", "app/user/sos-history/page.jsx", "app/user/sos-home/page.jsx", "app/user/sos-success/page.jsx", "app/user/sos-tracking/page.jsx", "app/user/users-chatBot/page.jsx", "app/user/users-login/page.jsx", "app/user/users-register/page.jsx", "app/layout.jsx", "app/page.jsx", "constants/buttons.js", "constants/cards.js", "constants/colors.js"  ],
  "exclude": ["node_modules"]
}
